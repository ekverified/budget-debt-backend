# ─────────────────────────────────────────────────────────────────
# Budget & Debt Coach Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env to Git.
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# MongoDB Atlas URI
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/budget_coach?retryWrites=true&w=majority

# Admin dashboard key — use a long random secret
ADMIN_API_KEY=replace_with_long_random_secret

# Your Render frontend URL (exact, no trailing slash) — used for CORS
FRONTEND_URL=https://budget-debt-coach-js.onrender.com

# Your Render backend URL — used by keep-alive cron
SELF_URL=https://budget-debt-backend.onrender.com

# Anthropic API key (optional)
# If set → real Claude Haiku AI advice (~$0.001 per call)
# If not set → high-quality rule-based advice is streamed instead
# Get key: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
